# ═══════════════════════════════════════════════════
#  Crypto Signal Bot — Konfiguracja (Docker)
#  Kopiuj: cp .env.example .env && edytuj
# ═══════════════════════════════════════════════════

# ── WYMAGANE ──────────────────────────────────────
DISCORD_WEBHOOK=https://discord.com/api/webhooks/TWOJ/WEBHOOK

# ── OPCJONALNE ────────────────────────────────────
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT,ADA/USDT,DOGE/USDT,AVAX/USDT,DOT/USDT,LINK/USDT
TIMEFRAMES=5m,15m,1h
SCAN_INTERVAL=60
TREND_FILTER=alert
MARKET=crypto

# AI Sentiment (używa darmowych RSS — CoinDesk, CoinTelegraph, CryptoNews)
SENTIMENT=false
FINNHUB_KEY=
CRYPTOPANIC_KEY=

# Pozycje
POSITION_SIZE=100

# Logowanie
LOG_LEVEL=INFO
TZ=Europe/Warsaw
